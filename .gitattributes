# Normalize line endings: store LF in git, checkout with native line endings
* text=auto

# Force LF for scripts and config — must not be CRLF on Mac/Linux
*.sh text eol=lf
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.env text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
Procfile text eol=lf
requirements.txt text eol=lf
runtime.txt text eol=lf

# Binary files — do not touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.rdb binary
